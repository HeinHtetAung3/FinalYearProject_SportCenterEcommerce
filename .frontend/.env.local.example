# Frontend env template. Copy to .env.local and tweak per machine.

# Backend API (Spring Boot). Leave as-is for the default Docker / local setup.
VITE_API_BASE_URL=http://localhost:8080

# Optional: customer storefront origin when the admin app is hosted separately (full page redirect).
# Example: http://localhost:3000/
# VITE_STOREFRONT_URL=

# Google Maps Platform — enable Places Autocomplete on checkout (address, city, postal, country).
# Create a key with "Places API" (and Maps JavaScript API) at https://console.cloud.google.com/google/maps-apis
# Restrict the key by HTTP referrer (e.g. http://localhost:5173/*) for production.
# VITE_GOOGLE_MAPS_API_KEY=

# Production builds: mock catalog/reviews are OFF unless you set this to true
# (e.g. static demo hosting without a Java API). Development always allows fallback.
# VITE_ALLOW_DEMO_FALLBACK=false

# Optional: show the yellow demo banner on a deployed build when using mock data.
# VITE_SHOW_DEMO_BANNER=false

# Firebase Storage bucket. Only used when VITE_PRODUCT_IMAGE_SOURCE=firebase.
VITE_FIREBASE_STORAGE_BUCKET=sportshub-demo.appspot.com

# Product / category image resolution. Default local uses product-image-manifest.json
# and files under public/images/products/.
#   local     — recommended (manifest + public assets).
#   firebase  — Firebase Storage paths when using VITE_FIREBASE_STORAGE_BUCKET.
#   unsplash  — legacy CDN fallback only.
VITE_PRODUCT_IMAGE_SOURCE=local
